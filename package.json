{
  "name": "agent-rules",
  "version": "0.1.0",
  "description": "Directory-scoped AI rule enforcement for PR reviews.",
  "type": "module",
  "private": true,
  "bin": {
    "agent-rules": "dist/cli.js"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "keywords": [
    "ai",
    "code-review",
    "pr-review",
    "linting",
    "anthropic",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^20.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "micromatch": "^4.0.0",
    "smol-toml": "^1.6.1",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "0.73.1",
    "@mariozechner/pi-coding-agent": "0.73.1"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
